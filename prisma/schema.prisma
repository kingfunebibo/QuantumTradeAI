generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ==========================
// Enums
// ==========================
//

enum Role {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum ExchangeType {
  BYBIT
  BINANCE
  KUCOIN
  MEXC
  BITGET
  GATE
}

enum ExchangeAccountType {
  SPOT
  FUTURES
  UNIFIED
  MARGIN
  OPTIONS
}

//
// ==========================
// User Management
// ==========================
//

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String

  firstName String?
  lastName  String?

  role Role @default(USER)

  // ==========================
  // Account Status
  // ==========================

  isActive      Boolean @default(true)
  emailVerified Boolean @default(false)

  // ==========================
  // Security
  // ==========================

  lastLoginAt DateTime?
  lastLoginIp String?

  // ==========================
  // Relations
  // ==========================

  auditLogs        AuditLog[]        @relation("AuditActor")
  exchangeAccounts ExchangeAccount[]

  // ==========================
  // Audit
  // ==========================

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ==========================
// Audit Logs
// ==========================
//

model AuditLog {
  id String @id @default(cuid())

  actorId String

  actor User @relation("AuditActor", fields: [actorId], references: [id])

  action String

  resource String

  resourceId String?

  details Json?

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([resource])
  @@index([action])
}

//
// ==========================
// Exchange Accounts
// ==========================
//

model ExchangeAccount {
  id String @id @default(cuid())

  // ==========================
  // Owner
  // ==========================

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ==========================
  // Exchange Information
  // ==========================

  exchange ExchangeType

  accountType ExchangeAccountType @default(SPOT)

  accountName String

  nickname String?

  // ==========================
  // Account Settings
  // ==========================

  isActive Boolean @default(true)

  testnet Boolean @default(false)

  lastSyncedAt DateTime?

  // ==========================
  // Relations
  // ==========================

  credential ExchangeCredential?

  // ==========================
  // Audit
  // ==========================

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([exchange])
  @@index([accountType])
}

//
// ==========================
// Exchange Credentials
// ==========================
//

model ExchangeCredential {
  id String @id @default(cuid())

  exchangeAccountId String @unique

  exchangeAccount ExchangeAccount @relation(fields: [exchangeAccountId], references: [id], onDelete: Cascade)

  // ==========================
  // Encrypted Credentials
  // ==========================

  encryptedApiKey String

  encryptedSecret String

  encryptedPassphrase String?

  // ==========================
  // Audit
  // ==========================

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
